{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@scoring": ["../src/lib/scoring/index.ts"],
      "@scoring/*": ["../src/lib/scoring/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../src/lib/scoring/**/*.ts"]
}
